{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug 01 - Task Basics",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/01_task_basics/lesson01.elf",
            "cwd": "${workspaceFolder}/01_task_basics",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "miDebuggerServerAddress": "localhost:1234",
            "debugServerPath": "/usr/bin/qemu-system-arm",
            "debugServerArgs": "-machine mps2-an385 -display none -serial stdio -monitor pty -kernel ${workspaceFolder}/01_task_basics/lesson01.elf -s -S",
            "serverStarted": "char device redirected",
            "serverLaunchTimeout": 5000,
            "preLaunchTask": "Build Lesson 01 - Task Basics",
            "setupCommands": [
                { "text": "set remotetimeout 10" }
            ]
        },
